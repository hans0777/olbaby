# ============================================
# 오엘베이비 고객관리 시스템 - 환경 변수
# ============================================
# 이 파일을 복사해서 실제 값을 입력하세요
# 파일명: .env (복사 후 이름 변경)

# ============================================
# Supabase 설정
# ============================================
# https://supabase.com 에서 프로젝트 생성 후
# Settings → API 에서 확인

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY

# ============================================
# 알리고 SMS API 설정
# ============================================
# https://aligo.in 가입 후
# 마이페이지 → API 연동 에서 확인

ALIGO_API_KEY=YOUR_ALIGO_API_KEY
ALIGO_USER_ID=YOUR_ALIGO_USER_ID
ALIGO_SENDER=01012345678

# ============================================
# 관리자 페이지 설정
# ============================================

ADMIN_PASSWORD=olbaby2026

# ============================================
# 웹페이지 배포 URL
# ============================================
# GitHub Pages 배포 후 입력
# 예: https://YOUR_USERNAME.github.io/olbaby

URL_GUIDE=https://YOUR_USERNAME.github.io/olbaby/guide.html
URL_OFFER=https://YOUR_USERNAME.github.io/olbaby/offer.html
URL_SURVEY=https://YOUR_USERNAME.github.io/olbaby/survey.html
URL_ADMIN=https://YOUR_USERNAME.github.io/olbaby/admin.html
